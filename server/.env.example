# Backend environment variables (Express server on Render)
# Set these in the Render dashboard under Environment > Environment Variables

# MongoDB Atlas connection string (get from atlas.mongodb.com)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/finance-tracker?retryWrites=true&w=majority

# JWT secret — Render can auto-generate this if you use render.yaml
JWT_SECRET=replace_with_a_long_random_secret

# Your Vercel frontend URL (set after deploying to Vercel)
CORS_ORIGIN=https://your-app.vercel.app

NODE_ENV=production
